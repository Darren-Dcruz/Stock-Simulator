# ─────────────────────────────────────────────────────────────
# StockSim Academy — environment variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────

# Finnhub API key (free at https://finnhub.io)
# Required for live NSE stock prices; app shows demo data without it
VITE_FINNHUB_KEY=your_finnhub_api_key_here

# Base44 app credentials (auto-set by Base44 — do not edit manually)
VITE_BASE44_APP_ID=
VITE_BASE44_APP_BASE_URL=
